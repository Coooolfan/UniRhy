{
  "name": "unirhy-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s typecheck:app typecheck:node build-only",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "run-s typecheck:app typecheck:node",
    "typecheck": "run-s typecheck:app typecheck:test typecheck:node",
    "typecheck:app": "vue-tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "vue-tsc -p tsconfig.vitest.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "lint": "oxlint . --type-aware --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "verify": "run-s lint typecheck",
    "fix": "run-s lint:fix",
    "api": "node script/generate-api.js",
    "tauri": "tauri",
    "tauri:check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "tauri:dev": "tauri dev"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-websocket": "^2.4.2",
    "echarts": "^6.1.0",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "tauri-plugin-android-battery-optimization-api": "0.1.0",
    "tauri-plugin-background-service": "0.7.1",
    "vue": "^3.5.38",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "adm-zip": "^0.5.17",
    "fs-extra": "^11.3.5",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.56.0",
    "oxlint": "~1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "temp-dir": "^3.0.0",
    "typescript": "~6.0.3",
    "uuid": "^14.0.1",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.3",
    "vite-plugin-vue-inspector-copy": "https://github.com/Coooolfan/vite-plugin-vue-inspector-copy/archive/refs/tags/v0.1.0.tar.gz",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
