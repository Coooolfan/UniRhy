{
  "name": "unirhy-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-s typecheck:app typecheck:node build-only",
    "electron:dev": "run-p --race dev electron:run:dev",
    "electron:run:dev": "run-s electron:build:main electron:start:dev",
    "electron:start:dev": "electron dist-electron/main.cjs",
    "electron:typecheck": "tsc -p electron/tsconfig.json --noEmit",
    "electron:bundle:main": "run-s electron:bundle:main:process electron:bundle:main:preload",
    "electron:bundle:main:process": "vite build --config vite.config.electron.ts --mode electron-main",
    "electron:bundle:main:preload": "vite build --config vite.config.electron.ts --mode electron-preload",
    "electron:build:main": "run-s electron:typecheck electron:bundle:main",
    "electron:pack": "electron-builder --config electron-builder.yml",
    "electron:build": "run-s build electron:build:main electron:pack",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "run-s typecheck:app typecheck:node",
    "typecheck": "run-s typecheck:app typecheck:test typecheck:node",
    "typecheck:app": "vue-tsc -p tsconfig.app.json --noEmit",
    "typecheck:test": "vue-tsc -p tsconfig.vitest.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "lint": "oxlint . --ignore-pattern \"dist-electron/**\" --ignore-pattern \"release/**\" --type-aware --deny-warnings",
    "lint:fix": "oxlint . --ignore-pattern \"dist-electron/**\" --ignore-pattern \"release/**\" --fix",
    "format": "oxfmt . --no-error-on-unmatched-pattern \"!dist-electron/**\" \"!release/**\"",
    "format:check": "oxfmt . --check --no-error-on-unmatched-pattern \"!dist-electron/**\" \"!release/**\"",
    "verify": "run-s lint typecheck",
    "fix": "run-s lint:fix",
    "api": "node script/generate-api.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/finalhandler": "^1.2.3",
    "@types/http-proxy": "^1.17.16",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^24.12.0",
    "@types/serve-static": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "adm-zip": "^0.5.16",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "finalhandler": "^2.1.0",
    "fs-extra": "^11.3.4",
    "http-proxy": "^1.18.1",
    "jsdom": "^28.1.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.40.0",
    "oxlint": "~1.55.0",
    "oxlint-tsgolint": "^0.16.0",
    "serve-static": "^2.2.0",
    "temp-dir": "^3.0.0",
    "typescript": "~5.9.3",
    "uuid": "^13.0.0",
    "vite": "^8.0.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
