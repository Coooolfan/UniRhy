{
  "identifier": "default",
  "description": "Default capabilities for UniRhy desktop",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://*:*" }, { "url": "https://*:*" }]
    },
    "websocket:default",
    "unirhy-playback:default",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",
    "android-battery-optimization:allow-check-battery-optimization-status",
    "android-battery-optimization:allow-open-battery-settings"
  ]
}
