{
  "name": "unirhy-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "oxlint . --type-aware --type-check -A all -A nursery --deny-warnings",
    "typecheck": "oxlint . --type-aware --type-check -A all -A nursery --deny-warnings",
    "lint": "oxlint . --type-aware --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "verify": "run-s lint typecheck",
    "fix": "run-s lint:fix"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "three": "^0.183.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "~1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-vue-devtools": "^8.1.0"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
