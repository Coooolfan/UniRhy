{
  "name": "unirhy-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/sync-shared-docs.mjs",
    "dev": "vite",
    "prebuild": "node ./scripts/sync-shared-docs.mjs",
    "build": "run-s type-check build:client build:server build:prerender",
    "build:client": "vite build",
    "build:server": "vite build --ssr src/entry-server.ts --outDir dist/server --emptyOutDir false",
    "build:prerender": "node ./scripts/prerender.mjs",
    "sync:docs": "node ./scripts/sync-shared-docs.mjs",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "oxlint . --type-aware --type-check -A all -A nursery --deny-warnings",
    "typecheck": "oxlint . --type-aware --type-check -A all -A nursery --deny-warnings",
    "lint": "oxlint . --type-aware --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "verify": "run-s lint typecheck",
    "fix": "run-s lint:fix"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "@unhead/ssr": "^3.1.1",
    "@unhead/vue": "^3.1.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.2.0",
    "three": "^0.184.0",
    "unhead": "^3.1.1",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^9.0.1",
    "oxfmt": "^0.53.0",
    "oxlint": "~1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-plugin-vue-inspector-copy": "https://github.com/Coooolfan/vite-plugin-vue-inspector-copy/archive/refs/tags/v0.1.0.tar.gz"
  },
  "engines": {
    "node": "^24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
